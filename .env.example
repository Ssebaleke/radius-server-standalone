RADIUS_SECRET_KEY=change-me-to-random-string
RADIUS_DEBUG=False
RADIUS_ALLOWED_HOSTS=radius.spotpay.it.com,localhost
RADIUS_CSRF_TRUSTED_ORIGINS=https://radius.spotpay.it.com
RADIUS_SITE_URL=https://radius.spotpay.it.com

# Supabase Postgres for Django (separate DB from SpotPay)
RADIUS_DATABASE_URL=postgresql://user:password@host:5432/radius_db

# FreeRADIUS MySQL
RADIUS_MYSQL_ROOT_PASSWORD=change-me-root-password
RADIUS_MYSQL_PASSWORD=change-me-radius-password
FREERADIUS_DB_HOST=radius-db
FREERADIUS_DB_PORT=3306
FREERADIUS_DB_NAME=radius
FREERADIUS_DB_USER=radius
FREERADIUS_DB_PASSWORD=change-me-radius-password
RADIUS_DEFAULT_SECRET=change-me-default-secret

# SpotPay SSO shared secret (must match SPOTPAY_SSO_SECRET in SpotPay .env)
SPOTPAY_SSO_SECRET=change-me-shared-sso-secret

# VPS IP for MikroTik config scripts
VPS_IP=68.168.222.37
